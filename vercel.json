{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "studiosbydave.com" }],
      "destination": "https://www.studiosbydave.com/:path",
      "permanent": true
    },
    {
      "source": "/studiosweb/web-design",
      "destination": "/studiosweb/webdesign",
      "permanent": true
    },
    {
      "source": "/studiosweb/ai-automations",
      "destination": "/studiosweb",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "studiosbydave-official-site-7422bd0-five.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
